# Supabase (Phase 2) – copy this file to .env and fill with your project values.
# Get URL and anon key from: Supabase Dashboard → Project Settings → API.
# Then run supabase/schema.sql in the SQL Editor to create tables and RLS.
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
